generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum AdPlatform {
  META
  GOOGLE
  LINKEDIN
  TIKTOK
  SNAPCHAT
  PINTEREST
  YOUTUBE
  TWITTER
  OTHER
}

enum AdSource {
  COMPETITOR_TRACKING
  DISCOVERY
}

enum AdFormat {
  DISPLAY   // Visual/image brand ad → shown in feed
  VIDEO     // Video ad → shown in feed
  SEARCH    // Text search ad (looks like SEO result) → SEO section only
  SHOPPING  // Product listing ad (price + product photo) → not in feed
}

enum LLMProvider {
  OPENAI
  PERPLEXITY
  ANTHROPIC
  GEMINI
}

enum ActivityType {
  AD_DETECTED
  EMAIL_RECEIVED
  SMS_RECEIVED
  SEO_CHANGED
  LLM_CHECKED
  COMPETITOR_ADDED
}

// ─────────────────────────────────────────────────────────────────────────────
// ORGANIZATION (multi-tenant)
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id         String   @id @default(cuid())
  clerkOrgId String   @unique
  name       String
  slug       String   @unique
  plan       Plan     @default(FREE)
  logoUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  competitors  Competitor[]
  activities   Activity[]

  @@map("organizations")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPETITOR
// ─────────────────────────────────────────────────────────────────────────────

model Competitor {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name          String
  website       String
  logoUrl       String?
  description   String?
  brandName     String? // Used for LLM visibility checks

  // Tracking email assigned to this competitor for inbound email capture
  trackingEmail String? @unique

  // Module toggles
  isActive   Boolean @default(true)
  trackAds   Boolean @default(true)
  trackEmails Boolean @default(false)
  trackSms    Boolean @default(false)
  trackSeo    Boolean @default(true)
  trackLlm    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ads          Ad[]
  emails       Email[]
  smsMessages  SMSMessage[]
  seoSnapshots SEOSnapshot[]
  llmScores    LLMScore[]

  @@index([organizationId])
  @@map("competitors")
}

// ─────────────────────────────────────────────────────────────────────────────
// ADS
// ─────────────────────────────────────────────────────────────────────────────

model Ad {
  id           String      @id @default(cuid())
  competitorId String?
  competitor   Competitor? @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  platform       AdPlatform
  format         AdFormat   @default(DISPLAY)
  source         AdSource   @default(COMPETITOR_TRACKING)
  advertiserName String?
  title          String?
  description    String?    @db.Text
  imageUrl       String? // Supabase Storage public URL
  imageKey       String?    // Supabase Storage object key
  ctaText        String?
  landingUrl     String?
  isActive       Boolean    @default(true)
  isStale        Boolean    @default(false)
  rawData        Json?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  @@index([competitorId])
  @@index([platform])
  @@index([format])
  @@index([source])
  @@index([firstSeenAt(sort: Desc)])
  @@map("ads")
}

// ─────────────────────────────────────────────────────────────────────────────
// EMAIL TRACKING
// ─────────────────────────────────────────────────────────────────────────────

model Email {
  id           String     @id @default(cuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  subject     String
  fromName    String?
  fromEmail   String?
  htmlContent String? @db.Text
  textContent String? @db.Text
  isRead      Boolean  @default(false)
  tags        String[]

  receivedAt DateTime @default(now())

  @@index([competitorId])
  @@map("emails")
}

// ─────────────────────────────────────────────────────────────────────────────
// SMS TRACKING
// ─────────────────────────────────────────────────────────────────────────────

model SMSMessage {
  id           String     @id @default(cuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  fromNumber String
  content    String  @db.Text
  isRead     Boolean @default(false)

  receivedAt DateTime @default(now())

  @@index([competitorId])
  @@map("sms_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// SEO MONITORING
// ─────────────────────────────────────────────────────────────────────────────

model SEOSnapshot {
  id           String     @id @default(cuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  url        String
  title      String?
  metaDesc   String?
  h1         String?
  keywords   String[]
  ogTitle    String?
  ogDesc     String?
  statusCode Int?
  loadTime   Int? // milliseconds

  // Change detection
  titleChanged   Boolean @default(false)
  metaChanged    Boolean @default(false)
  h1Changed      Boolean @default(false)

  checkedAt DateTime @default(now())

  @@index([competitorId])
  @@map("seo_snapshots")
}

// ─────────────────────────────────────────────────────────────────────────────
// LLM VISIBILITY
// ─────────────────────────────────────────────────────────────────────────────

model LLMScore {
  id           String      @id @default(cuid())
  competitorId String
  competitor   Competitor  @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  provider  LLMProvider
  prompt    String      @db.Text
  response  String      @db.Text
  mentioned Boolean     @default(false)
  position  Int? // rank in the response (1 = first mentioned)
  sentiment String? // positive | negative | neutral
  score     Float? // 0-1 visibility score

  checkedAt DateTime @default(now())

  @@index([competitorId])
  @@index([provider])
  @@map("llm_scores")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIVITY FEED
// ─────────────────────────────────────────────────────────────────────────────

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type           ActivityType
  title          String
  description    String?
  entityId       String? // ID of the related entity (adId, emailId, etc.)
  competitorName String?

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@map("activities")
}
