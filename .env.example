# ─── DATABASE ────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection strings
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ─── AUTH (CLERK) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── STORAGE (SUPABASE) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── SCRAPING ─────────────────────────────────────────────────────────────────
# Meta Ad Library API token (scraping HTTP, sans Playwright — fonctionne sur Vercel)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Optionnel: proxy pour le scraping Playwright
SCRAPING_PROXY_URL=

# ─── ADMIN ────────────────────────────────────────────────────────────────────
# Clerk userId de l'admin (laisse vide = tous les users accèdent à /dashboard/admin)
ADMIN_CLERK_ID=

# Railway deploy hook pour déclencher le massScrape depuis l'admin panel
# Crée-le dans Railway → service → Settings → Deploy Hooks
RAILWAY_DEPLOY_HOOK=https://backboard.railway.app/webhooks/deploy/...

# ─── EMAIL TRACKING ───────────────────────────────────────────────────────────
# Domaine pour les adresses emails de tracking (ex: tracking.mon-saas.com)
TRACKING_EMAIL_DOMAIN=tracking.spymark.io
# Webhook secret pour valider les requêtes entrantes
EMAIL_WEBHOOK_SECRET=whsec_...

# ─── SMS TRACKING (TWILIO) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+33...

# ─── LLM VISIBILITY ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-app-secret-key-min-32-chars
